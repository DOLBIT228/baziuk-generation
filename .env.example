# Required for real generations
OPENROUTER_API_KEY=sk-or-v1-your-key

# Recommended in production
SESSION_SECRET=replace-with-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-deploy

# Optional app metadata for OpenRouter rankings
APP_URL=https://your-domain.com
APP_TITLE=ImageGen UA

# Pricing and currency settings
USD_UAH_RATE=40
MODEL_INPUT_PRICE_PER_MILLION=2
MODEL_OUTPUT_PRICE_PER_MILLION=12
PORT=3000
